                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('rate_lock_id');",
                  "    pm.collectionVariables.set('rate_lock_id', jsonData.data.rate_lock_id);",
                  "});",
                  "",
                  "pm.test('Lock expires in 90 seconds', function() {",
                  "    var data = pm.response.json().data;",
                  "    var lockExpiry = new Date(data.lock_expires_at);",
                  "    var now = new Date();",
                  "    var diffSeconds = (lockExpiry - now) / 1000;",
